{
  "name": "@cyanideui/ui",
  "version": "1.2.1",
  "description": "Atrium UI - calm, content-first React component library for ERP and admin apps. Built with shadcn/ui patterns + Tailwind v4 + hugeicons (Stroke Rounded). Inspired by Notion, Shopify Polaris, and Linear.",
  "keywords": [
    "react",
    "design-system",
    "components",
    "ui",
    "tailwind",
    "tailwind-v4",
    "shadcn",
    "radix-ui",
    "erp",
    "admin",
    "dashboard"
  ],
  "license": "UNLICENSED",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanideui/atrium.git",
    "directory": "packages/ui"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src/styles"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./command-palette": {
      "types": "./dist/command-palette.d.ts",
      "import": "./dist/command-palette.js"
    },
    "./date-picker": {
      "types": "./dist/date-picker.d.ts",
      "import": "./dist/date-picker.js"
    },
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./styles/globals.css": "./src/styles/globals.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup && node scripts/add-use-client.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^1.0.16",
    "@hugeicons/react": "^1.0.5",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "react-day-picker": "^10.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.5"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^2.1.9",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
